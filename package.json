{
  "name": "aplicativo-transnet",
  "version": "0.2.2",
  "private": true,
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "node-cron": "^4.2.1",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.2",
    "react-scripts": "5.0.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^2.1.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-latest/xlsx-latest.tgz",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "start": "react-scripts start",
    "server": "node server.js",
    "dev": "concurrently -k -n \"SERVER,REACT\" -c \"cyan,green\" \"npm run server\" \"cross-env PORT=3000 npm run start\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron electron/main.js",
    "electron:build": "react-scripts build && electron-builder",
    "db:wipe": "node scripts/wipe-db.js",
    "db:wipe-op": "node scripts/wipe-operacional.js"
  },
  "homepage": "/",
  "build": {
    "appId": "com.transnet.operacional",
    "productName": "Transnet Operacional",
    "extends": null,
    "files": [
      "electron/main.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/appicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "tay-create",
      "repo": "transnet-operacional-v2"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:3001",
  "description": "This project was bootstrapped with [Create React App](https://github.com/facebook/create-react-app).",
  "main": "electron/main.js",
  "overrides": {
    "nth-check": "^2.0.1",
    "jsonpath": "^1.1.1",
    "minimatch": "^3.0.5",
    "cross-spawn": "^7.0.5",
    "dns-packet": "^1.3.4",
    "serialize-javascript": "^6.0.0",
    "loader-utils": "^2.0.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^25.0.0",
    "jest": "^27.5.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
