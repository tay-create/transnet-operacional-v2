# === ARQUIVO DE EXEMPLO - COPIE PARA .env E CONFIGURE ===

# Segurança JWT (ALTERE PARA UMA CHAVE ALEATÓRIA FORTE EM PRODUÇÃO!)
JWT_SECRET='transnet-secret-key-2026-ultra-secure-32-caracteres'

# Porta do Servidor
PORT=3001

# Limite de tamanho para uploads de imagens (em MB)
MAX_FILE_SIZE=10mb

# Ambiente (development, production)
NODE_ENV=development

GENERATE_SOURCEMAP=false

# Banco de Dados (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=transnet
DB_PASSWORD=124578595
DB_PORT=5432


# URL do Frontend (CORS - OBRIGATÓRIO EM PRODUÇÃO)
# Em dev deixe como localhost:3000; em produção coloque o domínio real
FRONTEND_URL=http://localhost:3000

# === INSTRUÇÕES ===
# 1. Copie este arquivo para .env
# 2. Substitua os valores de exemplo pelos valores reais
# 3. NUNCA faça commit do arquivo .env (já está no .gitignore)
# 4. Em produção, use uma chave JWT forte (mínimo 32 caracteres aleatórios)
# 5. Em produção, defina FRONTEND_URL com o domínio real (ex: https://app.transnet.com.br)
